{
  "name": "nova-content-creation",
  "version": "1.0.0",
  "description": "Portable Pi Coding Agent Workspace",
  "scripts": {
    "start": "node backend/server.js",
    "server": "node backend/server.js",
    "client": "npm run dev --prefix frontend",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "agent": "dotenv -- npx pi --model openai/gpt-5.5"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "axios": "^1.6.8",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "fast-xml-parser": "^5.9.3",
    "geoip-lite": "^2.0.3",
    "googlethis": "^1.8.0",
    "ical": "^0.8.0",
    "imap-simple": "^5.1.0",
    "mailparser": "^3.6.9",
    "marked": "^12.0.1",
    "node-cron": "^3.0.3",
    "simple-git": "^3.24.0"
  },
  "optionalDependencies": {
    "@earendil-works/pi-coding-agent": "latest",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^12.11.1",
    "concurrently": "^8.2.2",
    "dotenv-cli": "^7.3.0"
  }
}
