PORT=5000

# ── Kalıcı depolama (Supabase) ──────────────────────────────────────────────
# Bu ikisi AYARLANIRSA dashboard + design board verisi Supabase'de kalıcı
# olarak durur (Render free tier diskini sıfırlasa bile veri kaybolmaz).
# Boş bırakılırsa (lokal geliştirme) veri eskisi gibi yerel JSON dosyalarına
# yazılır. service_role anahtarı GİZLİDİR — yalnızca backend'de kalır.
# Supabase SQL Editor'de bir kez şu tabloyu oluşturun:
#   create table if not exists app_state (
#     key text primary key,
#     value jsonb not null,
#     updated_at timestamptz default now()
#   );
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# ── Giriş güvenliği (ortak parola) ──────────────────────────────────────────
# APP_PASSWORD tanımlıysa tüm /api rotaları giriş ister. Boşsa auth kapalı
# (yalnızca lokal geliştirme için). AUTH_SECRET token imzalamada kullanılır —
# üretimde rastgele uzun bir metinle değiştirin (değişince herkes yeniden giriş yapar).
APP_PASSWORD=change_me
AUTH_SECRET=change_me_to_a_long_random_string

# ── Özellik bayrakları ──────────────────────────────────────────────────────
# Virgülle ayrılmış liste. Boş = yalnızca çekirdek planlama (önerilen).
# Seçenekler: newsletter (RSS+SQLite), ocr (TrOCR el yazısı), ai (OpenRouter),
# sync (Notion/IMAP/ICS/Instagram + günlük 07:00 cron).
# Bir özelliği açmadan önce render.yaml'daki --omit=optional'ı kaldırmayı unutmayın.
FEATURES=

OPENAI_API_KEY=your_openai_api_key_here
# Alternative: GEMINI_API_KEY=your_gemini_api_key_here

# Notion Integration
NOTION_API_KEY=your_notion_api_key_here
NOTION_DATABASE_ID=your_notion_database_id_here

# Email Sync (Gmail/Outlook IMAP)
GMAIL_USER=your_gmail_address@gmail.com
GMAIL_APP_PASSWORD=abcd_efgh_ijkl_mnop
OUTLOOK_USER=your_outlook_address@outlook.com
OUTLOOK_APP_PASSWORD=your_outlook_app_password

# Calendar ICS URL feeds
GOOGLE_CALENDAR_ICS_URL=https://calendar.google.com/calendar/ical/.../basic.ics
OUTLOOK_CALENDAR_ICS_URL=https://outlook.live.com/owa/calendar/.../reachcalendar.ics

# Instagram Configuration
INSTAGRAM_MY_USERNAME=your_instagram_handle
INSTAGRAM_COMPETITORS=influencer_one,influencer_two,influencer_three
